{
  "name": "claude-codex-bridge",
  "version": "0.1.0",
  "description": "Local MCP-backed bridge that lets Claude delegate planning and review tasks to Codex CLI.",
  "main": "dist/src/server.js",
  "homepage": "https://github.com/salexandr0s/claude-codex-bridge#readme",
  "bugs": {
    "url": "https://github.com/salexandr0s/claude-codex-bridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salexandr0s/claude-codex-bridge.git"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "smoke:tasks": "node scripts/smoke-task-support.mjs",
    "lint": "eslint . --ext .ts",
    "verify": "npm run lint && npm run build && npm run test",
    "install:local": "node scripts/install-local.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
